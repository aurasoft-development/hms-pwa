{
  "name": "hotel-management",
  "version": "1.0.0",
  "description": "Hotel Management Desktop App",
  "main": "public/electron.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && node -e \"require('fs').copyFileSync('public/electron.js', 'electron.js')\" && electron-builder && node -e \"try { require('fs').unlinkSync('electron.js'); } catch(e) {}\"",
    "electron:pack": "npm run build && node -e \"require('fs').copyFileSync('public/electron.js', 'electron.js')\" && electron-builder --dir && node -e \"try { require('fs').unlinkSync('electron.js'); } catch(e) {}\"",
    "start": "npm run electron:dev"
  },
  "keywords": [
    "hotel",
    "management",
    "electron",
    "react"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "date-fns": "^2.30.0",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.294.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.3",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.8",
    "vite-plugin-pwa": "^0.17.0",
    "wait-on": "^7.2.0"
  }
}